{
  "openapi": "3.1.1",
  "info": {
    "title": "Monolegal API",
    "version": "v1"
  },
  "servers": [
    {
      "url": "http://localhost:5155/"
    }
  ],
  "paths": {
    "/api/settings/invoice-transitions": {
      "get": {
        "tags": [
          "Settings"
        ],
        "summary": "Obtener la configuración de transiciones",
        "description": "Devuelve la configuración actual de transiciones automáticas de facturas.",
        "operationId": "GetInvoiceTransitions",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "put": {
        "tags": [
          "Settings"
        ],
        "summary": "Actualizar la configuración de transiciones",
        "description": "Reemplaza la configuración de transiciones automáticas de facturas. Devuelve 204 sin contenido.",
        "operationId": "UpdateInvoiceTransitions",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InvoiceTransitionsConfig"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "No Content"
          }
        }
      }
    },
    "/api/settings/email": {
      "get": {
        "tags": [
          "Settings"
        ],
        "summary": "Obtener la configuración de email",
        "description": "Devuelve la configuración no secreta del proveedor de email y el estado de su credencial. Nunca expone secretos.",
        "operationId": "GetEmailSettings",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "put": {
        "tags": [
          "Settings"
        ],
        "summary": "Actualizar la configuración de email",
        "description": "Reemplaza la configuración no secreta del proveedor de email. Devuelve 204. Los secretos siguen viniendo del entorno.",
        "operationId": "UpdateEmailSettings",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EmailSettingsRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "No Content"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpValidationProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/settings/email/validate": {
      "post": {
        "tags": [
          "Settings"
        ],
        "summary": "Validar la credencial del proveedor de email",
        "description": "Valida la credencial del proveedor activo (o el indicado) sin enviar correo. Nunca expone el secreto.",
        "operationId": "ValidateEmailCredentials",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "type": "null"
                  },
                  {
                    "$ref": "#/components/schemas/ValidateEmailRequest"
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/settings/email/templates": {
      "get": {
        "tags": [
          "Settings"
        ],
        "summary": "Listar las plantillas de email",
        "description": "Devuelve las plantillas efectivas por tipo y el catálogo de variables admitidas.",
        "operationId": "GetEmailTemplates",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/settings/email/templates/{type}": {
      "put": {
        "tags": [
          "Settings"
        ],
        "summary": "Actualizar una plantilla de email",
        "description": "Reemplaza el asunto y cuerpo de la plantilla del tipo indicado. Devuelve 204.",
        "operationId": "UpdateEmailTemplate",
        "parameters": [
          {
            "name": "type",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EmailTemplateInput"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "No Content"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/api/settings/email/templates/{type}/reset": {
      "post": {
        "tags": [
          "Settings"
        ],
        "summary": "Restablecer una plantilla de email",
        "description": "Elimina la personalización de la plantilla del tipo indicado, volviendo al default. Devuelve 204.",
        "operationId": "ResetEmailTemplate",
        "parameters": [
          {
            "name": "type",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/api/settings/email/templates/{type}/preview": {
      "post": {
        "tags": [
          "Settings"
        ],
        "summary": "Previsualizar una plantilla de email",
        "description": "Renderiza la plantilla con datos de ejemplo. Aplica la misma validación de variables que la edición.",
        "operationId": "PreviewEmailTemplate",
        "parameters": [
          {
            "name": "type",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EmailTemplateInput"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/api/settings/email/test": {
      "post": {
        "tags": [
          "Settings"
        ],
        "summary": "Enviar un correo de prueba",
        "description": "Envía un correo de prueba con el proveedor y la plantilla reales. Un fallo de envío se reporta como resultado, no como error 5xx.",
        "operationId": "SendTestEmail",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendTestEmailInput"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpValidationProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/settings/email/tools/resend-failed": {
      "post": {
        "tags": [
          "Settings"
        ],
        "summary": "Reenviar notificaciones fallidas",
        "description": "Reintenta el envío de las notificaciones de todas las facturas con último resultado Failed. Devuelve conteos (attempted/resent/failed).",
        "operationId": "ResendFailedNotifications",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/settings/email/tools/sanitize": {
      "post": {
        "tags": [
          "Settings"
        ],
        "summary": "Sanear notificaciones atascadas",
        "description": "Marca como Failed las facturas en estado notificable con notificación no registrada (None), conservando el registro. No reintenta ni borra.",
        "operationId": "SanitizeStuckNotifications",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/settings/maintenance/delete-all-data": {
      "post": {
        "tags": [
          "Settings"
        ],
        "summary": "Eliminar todos los datos",
        "description": "Elimina todos los registros de negocio (facturas) conservando la base de datos y la configuración del sistema. Irreversible.",
        "operationId": "DeleteAllData",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/settings/maintenance/flush-database": {
      "post": {
        "tags": [
          "Settings"
        ],
        "summary": "Flush DB",
        "description": "Vacía toda la base de datos (incluida la configuración), reconstruye índices y ejecuta nuevamente el sembrador de datos. Irreversible.",
        "operationId": "FlushDatabase",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/invoices/{id}/pay": {
      "post": {
        "tags": [
          "Invoices"
        ],
        "summary": "Marcar una factura como pagada",
        "description": "Aplica la transición de pago a la factura indicada desde cualquier estado activo válido. Devuelve 404 si la factura no existe y 409 si el estado actual no permite el pago.",
        "operationId": "PayInvoice",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not Found"
          },
          "409": {
            "description": "Conflict"
          }
        }
      }
    },
    "/api/invoices": {
      "get": {
        "tags": [
          "Invoices"
        ],
        "summary": "Listar facturas",
        "description": "Devuelve una lista paginada de facturas, opcionalmente filtrada por estado (query param 'status') y por cliente (query param 'search', coincidencia case-insensitive sobre clientId, máximo 100 caracteres). Admite paginación con 'page' y 'pageSize' (máximo 50).",
        "operationId": "ListInvoices",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PagedResponseOfInvoiceListItemDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpValidationProblemDetails"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Invoices"
        ],
        "summary": "Crear factura",
        "description": "Crea una factura con cliente, items y fecha de vencimiento. El monto se deriva de los items.",
        "operationId": "CreateInvoice",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateInvoiceRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvoiceDetailDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpValidationProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/invoices/{id}": {
      "get": {
        "tags": [
          "Invoices"
        ],
        "summary": "Obtener el detalle de una factura",
        "description": "Devuelve el objeto completo de la factura indicada por su identificador. Un identificador inexistente o con formato inválido devuelve 404 de forma uniforme.",
        "operationId": "GetInvoiceById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvoiceDetailDto"
                }
              }
            }
          },
          "404": {
            "description": "Not Found"
          }
        }
      },
      "put": {
        "tags": [
          "Invoices"
        ],
        "summary": "Editar factura",
        "description": "Edita cliente, items y vencimiento de una factura no terminal. Recalcula el monto.",
        "operationId": "UpdateInvoice",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateInvoiceRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvoiceDetailDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpValidationProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Not Found"
          },
          "409": {
            "description": "Conflict"
          }
        }
      },
      "delete": {
        "tags": [
          "Invoices"
        ],
        "summary": "Eliminar factura",
        "description": "Elimina permanentemente una factura (hard delete), en cualquier estado.",
        "operationId": "DeleteInvoice",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/api/invoices/transition/{id}": {
      "post": {
        "tags": [
          "Invoices"
        ],
        "summary": "Transicionar el estado de una factura",
        "description": "Aplica una transición manual de estado a la factura indicada. El cuerpo debe incluir 'newStatus'. Devuelve 400 si el cuerpo es inválido o la transición no está permitida, y 404 si la factura no existe.",
        "operationId": "TransitionInvoice",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TransitionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvoiceDetailDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/api/invoices/stats": {
      "get": {
        "tags": [
          "Invoices"
        ],
        "summary": "Obtener estadísticas de facturas",
        "description": "Devuelve métricas agregadas para el dashboard: total de facturas, conteo por estado ('byStatus') y conteo por cliente ('byClient').",
        "operationId": "GetInvoiceStats",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvoiceStatsDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/invoices/shipments": {
      "get": {
        "tags": [
          "Invoices"
        ],
        "summary": "Listar envíos",
        "description": "Devuelve una lista paginada de envíos por factura (sólo facturas en estados notificables), opcionalmente filtrada por estado de envío (query 'sendStatus': pending/sent/failed/skipped) y por cliente o correo (query 'search', coincidencia case-insensitive, máximo 100 caracteres). Admite 'page' y 'pageSize' (máximo 50).",
        "operationId": "ListShipments",
        "parameters": [
          {
            "name": "sendStatus",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PagedResponseOfShipmentListItemDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpValidationProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/invoices/{id}/resend": {
      "post": {
        "tags": [
          "Invoices"
        ],
        "summary": "Reenviar notificación de una factura",
        "description": "Reenvía la notificación correspondiente al estado actual de la factura e incrementa el contador de reintentos. Fail-soft: un fallo de envío se refleja como 'failed' (HTTP 200). Devuelve el ítem de envío actualizado.",
        "operationId": "ResendInvoice",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShipmentListItemDto"
                }
              }
            }
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/api/invoices/{id}/cancel-notification": {
      "post": {
        "tags": [
          "Invoices"
        ],
        "summary": "Cancelar envío de una factura",
        "description": "Marca como omitida la notificación de una factura pendiente en estado notificable, para que el worker no la procese. Conserva el registro. Devuelve 409 si la factura no está pendiente y 404 si no existe.",
        "operationId": "CancelInvoiceNotification",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShipmentListItemDto"
                }
              }
            }
          },
          "404": {
            "description": "Not Found"
          },
          "409": {
            "description": "Conflict"
          }
        }
      }
    },
    "/api/clients": {
      "get": {
        "tags": [
          "Clients"
        ],
        "summary": "Listar clientes",
        "description": "Lista paginada de clientes, con búsqueda opcional (query 'search') por nombre o email.",
        "operationId": "ListClients",
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PagedResponseOfClientDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpValidationProblemDetails"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Clients"
        ],
        "summary": "Crear cliente",
        "operationId": "CreateClient",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateClientRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpValidationProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/clients/{id}": {
      "get": {
        "tags": [
          "Clients"
        ],
        "summary": "Detalle de cliente",
        "operationId": "GetClientById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientDto"
                }
              }
            }
          },
          "404": {
            "description": "Not Found"
          }
        }
      },
      "put": {
        "tags": [
          "Clients"
        ],
        "summary": "Editar cliente",
        "operationId": "UpdateClient",
        "parameters": [
          {
            "name": "id",
            "in": "path",

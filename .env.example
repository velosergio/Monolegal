# =============================================================================
# Variables de entorno — copia este archivo a .env y ajusta los valores
# NUNCA commitear .env con valores reales
# =============================================================================

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development

# MongoDB
MONGODB_URI=mongodb://root:example_dev_password@mongo:27017/monolegal_dev?authSource=admin

# Frontend
VITE_API_URL=http://localhost:5000

# Logging
LOG_LEVEL=Debug

# Email provider (Development: console | Production: sendgrid | smtp)
EMAIL_PROVIDER=console

# =============================================================================
# Variables de entorno — copia este archivo a .env y ajusta los valores
# NUNCA commitear .env con valores reales
# =============================================================================

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development

# MongoDB
MONGODB_URI=mongodb://root:example_dev_password@mongo:27017/monolegal_dev?authSource=admin

# Frontend
VITE_API_URL=http://localhost:5000

# Logging
LOG_LEVEL=Debug

# Email provider (Development: console | Production: sendgrid | smtp)
EMAIL_PROVIDER=console

# SMTP
Email__Host=
Email__Port=587
Email__Username=
Email__Password=
Email__UseStartTls=true
Email__From=no-reply@monolegal.local
Email__FromName=Monolegal
# Resend (API key SECRETA)
Email__Resend__ApiKey=
Email__Resend__FromDomain=
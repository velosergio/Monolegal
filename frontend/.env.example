VITE_API_URL=http://localhost:5000

# URL de Swagger UI usada por el acceso "API (Swagger)" del sidebar (spec 025).
# Por defecto /swagger (reenviado al backend por el proxy de desarrollo de Vite).
# Déjala vacía para ocultar el acceso (p. ej. en producción con Swagger deshabilitado).
VITE_SWAGGER_URL=/swagger
